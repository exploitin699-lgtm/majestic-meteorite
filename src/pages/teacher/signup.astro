---
import MainLayout from "../../layouts/MainLayout.astro";


const SUBJECTS = [
  "Mathematics",
  "Physics",
  "Chemistry",
  "Biology",
  "Geography",
  "History and Political Education",
  "English",
  "Literature in English",
  "Kiswahili",
  "French",
  "German",
  "Chinese",
  "Arabic",
  "ICT",
  "CRE",
  "Entrepreneurship",
  "Technology and Design",
  "Fine Art",
  "Performing Arts",
  "Agriculture",
  "Food and Nutrition Technology",
  "Physical Education",
  "Religious Education",
  "IRE",
  "Local Languages"
];

const CLASSES = ["S1","S2","S3","S4","S5","S6"];
---

<MainLayout title="Teacher Signup">

<section class="section">

<h1>👩🏽‍🏫 Teacher registration</h1>

<form id="teacherForm" class="card form">

<label>
Full name
<input type="text" name="full_name" required />
</label>

<label>
Email
<input type="email" name="email" required />
</label>

<label>
Password
<input type="password" name="password" required />
</label>

<h3>Subjects you teach</h3>
<div class="grid small">
  {SUBJECTS.map(s => (
    <label class="check">
      <input type="checkbox" name="subjects" value={s} />
      {s}
    </label>
  ))}
</div>

<h3>Classes you teach</h3>
<div class="grid small">
  {CLASSES.map(c => (
    <label class="check">
      <input type="checkbox" name="class_levels" value={c} />
      {c}
    </label>
  ))}
</div>

<p id="formMsg" style="color:red;"></p>

<button type="submit" class="primary">
Create account
</button>

</form>

</section>

<script type="module">
const form = document.querySelector("#teacherForm");
const msg = document.getElementById("formMsg");

// Detect if running in local development
const isLocalDev = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1";

form.addEventListener("submit", async (e) => {
  e.preventDefault();
  msg.textContent = "";

  const fd = new FormData(form);
  const subjects = fd.getAll("subjects");
  const class_levels = fd.getAll("class_levels");

  if (subjects.length === 0 || class_levels.length === 0) {
    msg.textContent = "Please select at least one subject and class level";
    msg.style.color = "red";
    return;
  }

  const data = {
    email: fd.get("email"),
    password: fd.get("password"),
    full_name: fd.get("full_name"),
    subjects,
    class_levels,
  };

  msg.textContent = "Creating account...";
  msg.style.color = "blue";

  try {
    // In local development, Firebase functions emulator runs on a different port
    // Use the standard /api/teacher-signup which works via firebase emulator and Firebase Hosting
    const response = await fetch("/api/teacher-signup", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });

    let result;
    try {
      result = await response.json();
    } catch (e) {
      console.error("Failed to parse response:", e);
      
      if (isLocalDev && response.status === 404) {
        msg.textContent = "❌ Local Development: Please run Firebase emulator. See SETUP_LOCAL_DEV.md";
        msg.style.color = "orange";
      } else {
        msg.textContent = `Server error (${response.status}). Please try again later.`;
        msg.style.color = "red";
      }
      return;
    }

    if (response.ok) {
      msg.textContent = "✓ Account created! Redirecting...";
      msg.style.color = "green";
      setTimeout(() => {
        window.location.href = "/teacher/login";
      }, 1500);
    } else {
      msg.textContent = result.error || `Signup failed (${response.status}). Please try again.`;
      msg.style.color = "red";
    }
  } catch (error) {
    console.error("Network error:", error);
    msg.textContent = "Network error: " + error.message;
    msg.style.color = "red";
  }
});
</script>

</MainLayout>
